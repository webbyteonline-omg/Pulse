{
  "name": "Pulse — College Life Dashboard",
  "short_name": "Pulse",
  "description": "Attendance, academic calendar and money — everything a college student needs, in one place.",
  "start_url": "/dashboard",
  "id": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "background_color": "#0F0F13",
  "theme_color": "#6C63FF",
  "categories": ["education", "productivity", "finance"],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Today's Attendance",
      "short_name": "Attendance",
      "url": "/attendance",
      "icons": [{ "src": "/icons/attendance.png", "sizes": "96x96" }]
    },
    {
      "name": "Add Expense",
      "short_name": "Expense",
      "url": "/finance/add",
      "icons": [{ "src": "/icons/finance.png", "sizes": "96x96" }]
    },
    {
      "name": "Today's Classes",
      "short_name": "Classes",
      "url": "/timetable",
      "icons": [{ "src": "/icons/academic.png", "sizes": "96x96" }]
    }
  ],
  "widgets": [
    {
      "name": "Pulse Today",
      "description": "Today's attendance, spend and classes at a glance",
      "tag": "pulse-today",
      "template": "pulse-today-widget",
      "ms_ac_template": "/widgets/pulse-today.json",
      "data": "/api/widgets/today",
      "type": "application/json",
      "screenshots": [],
      "icons": [{ "src": "/icons/widget.png", "sizes": "192x192" }],
      "backgrounds": []
    }
  ]
}
